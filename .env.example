# Copy this file to .env and fill in your key:  cp .env.example .env
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: override the model. Defaults to claude-haiku-4-5 (cheapest/fastest).
# Use claude-sonnet-4-6 for sharper writing, or claude-opus-4-7 for top quality.
# BRIEF_MODEL=claude-haiku-4-5

# Optional: the "read more" link Alexa requires (must be a valid https URL).
# Defaults to the GitHub Pages site that hosts the feed.
# BRIEF_REDIRECT_URL=https://osher252.github.io/daily-brief/

# Optional: email the full brief each run via Resend. Leave RESEND_API_KEY
# unset to disable. Free-tier Resend only delivers to your own account email,
# so keep BRIEF_EMAIL_FROM as onboarding@resend.dev unless you verify a domain.
# RESEND_API_KEY=re_your_key_here
# BRIEF_EMAIL_TO=imjohnny252@gmail.com
# BRIEF_EMAIL_FROM=Daily Brief <onboarding@resend.dev>
